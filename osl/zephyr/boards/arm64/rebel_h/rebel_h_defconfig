# Arch/Core level
CONFIG_SOC_REBEL_H=y
CONFIG_ARM_MMU=y
CONFIG_ARM64_PA_BITS_48=y
CONFIG_ARM64_VA_BITS_48=y
CONFIG_MAX_XLAT_TABLES=32

# SOC/System level
CONFIG_BOARD_REBEL_H=y
CONFIG_ARM_ARCH_TIMER=y
CONFIG_ARMV8_A_NS=y

# Board level
# Enable UART driver
CONFIG_SERIAL=y

# Enable console
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y

# Debug
CONFIG_OUTPUT_DISASSEMBLY=y
CONFIG_OUTPUT_SYMBOLS=y

CONFIG_KERNEL_BIN_NAME="rebel_h.zephyr"

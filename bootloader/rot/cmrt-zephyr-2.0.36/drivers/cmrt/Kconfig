	  Enable Brainpool P384 T1 curve

config CMRT_PKE_BRAINPOOL_P512T1
	bool "Enable brainpool P512 T1 curve"
	depends on (CMRT_PKE_VERSION >= 0x040000) && !CMRT_FBOOT

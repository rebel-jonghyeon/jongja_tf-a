config CMRT_PKE_SM2_CURVE
	bool "Enable SM2 curve"
	depends on (CMRT_PKE_VERSION >= 0x040000) && !CMRT_FBOOT
	default n
	help
	  Enable SM2 curve

config CMRT_EDDSA
	bool "Enable EdDSA"
	depends on CMRT_PKE_ED25519_CURVE || CMRT_PKE_ED448_CURVE
	default y
	help
	  Enable EdDSA

config CMRT_PKE_ED25519_CURVE
	bool "Enable ed25519 Curve"
	depends on (CMRT_PKE_VERSION >= 0x030000) && !CMRT_FBOOT
	default y
	help
	  Enable ed25519 curve


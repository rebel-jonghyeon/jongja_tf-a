config CMRT_PKE_FRP256_CURVE
	bool "Enable ANSSI FRP256v1 curve"
	depends on (CMRT_PKE_VERSION >= 0x030000) && !CMRT_FBOOT
	default y
	help
	  Enable ANSSI FRP256v1 curve

config CMRT_PMU
	bool "Enable the Power Management Unit (PMU)"
	default n
	depends on CMRT_SIC || CMRT_SIC2
	help
	  Enable the Power Management Unit (PMU) support in the SIC driver.
	  If enabled, waking up from sleep will restore all OS state.
	  If disabled, waking up from sleep will reboot and restart the OS.

config CMRT_SAC
	bool "Enable System Aperture Core (SAC)"
	default n
	help
	  Enable System Aperture Core (SAC) driver.

config CMRT_SAC2
	bool "Enable 64bit System Aperture Core (SAC2)"
	default y if !CMRT_SAC
	help
	  Enable 64bit System Aperture Core (SAC2) driver.

config CMRT_SAC_CONSOLE
	bool "Copy RAM console messages to SAC memory"
	depends on RAM_CONSOLE && (CMRT_SAC || CMRT_SAC2)
	default y if DEBUG
	default n
	help
	  Copying takes place when CMRT has nothing to do or when CMRT is
	  about to halt. Console buffer size is RAM_CONSOLE_BUFFER_SIZE and
	  it is located at the end of FPGA visible SAC memory.

config CMRT_SAC_ACCESS_FIXUP
	bool "Enable trap handler translation of SAC accesses"
	depends on CMRT_SAC2
	default n
	help
	  The new 64bit SAC does not map the SAC window to CMRT memory space
	  anymore. Accesses to the old SAC window will cause CPU trap which
	  normally kills the thread. However, if this option is enabled,
	  the trap handler will resolve the access and program execution
	  will continue as if access worked normally.

config CMRT_SIC
	bool "Enable System Interface Core (SIC)"
	default n
	help
	  Enable System Interface Core (SIC) driver.

config CMRT_SIC2
	bool "Enable System Interface Core (SIC2)"
	default y if !CMRT_SIC
	help
	  Enable System Interface Core (SIC2) driver with SIC messaging
	  protocol v2.

config CMRT_SID
	bool "Enable SOC IRQ driver (SID)"
	default n
	depends on CMRT_SIC || CMRT_SIC2
	select DYNAMIC_INTERRUPTS
	help
	  Enable SOC IRQ driver (SID).

config CMRT_TMC
	bool "Enable TRNG Management Core (TMC)"
	default y
	help
	  Enable TRNG Management Core (TMC) Driver.

config CMRT_WDT
	bool "Enable CMRT Watchdog wrapper"
	depends on WDT_CMRT && SUPERVISOR_MODE
	select TASK_WDT
	default n
	help
	  Enable CMRT Watchdog wrapper.

config TEST_REBEL_H
	bool "Enable test features for REBEL_H"
	default n
	help
	  Enable test features for REBEL_H
	  This support receiving test commends through mailbox
	  Currently in use only in supervisor mw
	  please refer config-develop.mk for detail

source "drivers/cmrt/teefs/Kconfig"

